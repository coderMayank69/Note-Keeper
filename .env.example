# Note-Keeper Environment Variables
# Copy this file to .env and fill in your values
# Usage: docker-compose up --build

# ============================================
# CLIENT-SIDE (Firebase - used at Docker build time)
# ============================================
# Get from Firebase Console > Project Settings > General > Your apps
VITE_FIREBASE_API_KEY=AIzaSyCN7jc2UfXnLiKbR1G3Pb5dwMnY_NOLmtI
VITE_FIREBASE_AUTH_DOMAIN=projects-4f4c8.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=projects-4f4c8
VITE_FIREBASE_STORAGE_BUCKET=projects-4f4c8.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=861423578334
VITE_FIREBASE_APP_ID=1:861423578334:web:618cc2b6afa381428a664f
VITE_FIREBASE_MEASUREMENT_ID=G-X4FG6JWMZ6

# ============================================
# SERVER-SIDE (used at runtime)
# ============================================

# MongoDB Connection String
# For Docker Compose with local mongo: mongodb://mongo:27017/notekeeper
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/notekeeper
# For external hosting without mongo container: use your MongoDB Atlas URL
DB_URL=mongodb+srv://mayankbca96325_db_user:YBWOU3VDlALL9N2H@cluster0.txdmy8w.mongodb.net/?appName=Cluster0;

# Firebase Service Account JSON (single-line stringified)
# Get from Firebase Console > Project Settings > Service Accounts > Generate New Private Key
# To stringify: cat serviceAccountKey.json | jq -c '.'
# Or on Windows PowerShell: (Get-Content serviceAccountKey.json -Raw) -replace '\s+', ' '
FIREBASE_SERVICE_ACCOUNT=firebase-adminsdk-fbsvc@projects-4f4c8.iam.gserviceaccount.com
